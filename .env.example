# Copy to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
# Then $REPO_ROOT/.env is auto-sourced by every slurm/*.sbatch script.

# Required for gated models (Llama3-Instruct, etc.). Get one at
#   https://huggingface.co/settings/tokens
HF_TOKEN=hf_replace_me

# Optional: also lets the official `huggingface_hub` library auth without
# a separate `huggingface-cli login` step.
HUGGING_FACE_HUB_TOKEN=hf_replace_me

# Required for the attack experiments (slurm/persuasion_attack.sbatch and
# slurm/paraphrase_attack.sbatch). Get one at:
#   https://console.anthropic.com/settings/keys
# Used by experiments/_anthropic_rewriter.py for high-quality prompt
# rewrites. Default is claude-haiku-4-5-20251001 (cheapest); override
# with --api-model claude-sonnet-4-6 if you want a stronger rewriter.
ANTHROPIC_API_KEY=sk-ant-replace_me

# --- Optional overrides (omit to use slurm-script defaults) ---
# BLUEDOT_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# BLUEDOT_BS=8
# BLUEDOT_FILTER_TRAIN=1
# BLUEDOT_POLY_ROOT=/work/.../Multilingual-Refusal/dataset
# BLUEDOT_ARTIFACTS=/project/.../bluedot-artifacts
